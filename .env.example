# ========================================
# تنظیمات اصلی برنامه
# ========================================

# نام برنامه
APP_NAME="پلتفرم مزایده ایرانی"

# محیط اجرا: local, production
APP_ENV=local

# کلید رمزنگاری (با php artisan key:generate تولید شود)
APP_KEY=

# حالت دیباگ: true در محیط توسعه، false در محیط تولید
APP_DEBUG=true

# آدرس اصلی برنامه
APP_URL=http://localhost

# زبان پیش‌فرض (fa برای فارسی)
APP_LOCALE=fa
APP_FALLBACK_LOCALE=en

# منطقه زمانی (تهران)
APP_TIMEZONE=Asia/Tehran

# ========================================
# تنظیمات لاگ
# ========================================

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ========================================
# تنظیمات دیتابیس
# ========================================

# نوع دیتابیس: mysql, pgsql, sqlite
DB_CONNECTION=mysql

# آدرس سرور دیتابیس
DB_HOST=127.0.0.1

# پورت دیتابیس (3306 برای MySQL)
DB_PORT=3306

# نام دیتابیس
DB_DATABASE=haraj

# نام کاربری دیتابیس
DB_USERNAME=root

# رمز عبور دیتابیس
DB_PASSWORD=

# ========================================
# تنظیمات کش و صف
# ========================================

# درایور Broadcast: log, pusher, redis
BROADCAST_DRIVER=log

# درایور کش: file, redis, memcached
# توصیه: redis برای محیط تولید
CACHE_DRIVER=file

# درایور فایل‌ها: local, s3, public
FILESYSTEM_DISK=local

# درایور صف: sync, database, redis, sqs
# توصیه: redis یا database برای محیط تولید
QUEUE_CONNECTION=sync

# درایور Session: file, cookie, database, redis
SESSION_DRIVER=file

# مدت زمان Session (دقیقه)
SESSION_LIFETIME=120

# ========================================
# تنظیمات Redis (اختیاری)
# ========================================

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ========================================
# تنظیمات ایمیل
# ========================================

# سرویس ایمیل: smtp, mailgun, ses, postmark
MAIL_MAILER=smtp

# آدرس سرور SMTP
MAIL_HOST=mailpit

# پورت SMTP (587 برای TLS، 465 برای SSL)
MAIL_PORT=1025

# نام کاربری SMTP
MAIL_USERNAME=null

# رمز عبور SMTP
MAIL_PASSWORD=null

# رمزنگاری: tls, ssl, null
MAIL_ENCRYPTION=null

# آدرس ایمیل فرستنده
MAIL_FROM_ADDRESS="noreply@haraj.test"

# نام فرستنده
MAIL_FROM_NAME="${APP_NAME}"

# ========================================
# تنظیمات Sanctum (API Authentication)
# ========================================

# دامنه‌های مجاز برای SPA
SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1

# ========================================
# تنظیمات AWS S3 (اختیاری - برای ذخیره فایل)
# ========================================

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ========================================
# تنظیمات Pusher (اختیاری - برای Real-time)
# ========================================

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# ========================================
# تنظیمات اختصاصی پروژه
# ========================================

# مدت زمان مهلت پرداخت برنده (ساعت)
AUCTION_PAYMENT_DEADLINE_HOURS=48

# درصد سپرده مزایده (10 = 10%)
AUCTION_DEPOSIT_PERCENTAGE=10

# حداکثر تعداد تلاش برای پردازش مزایده
AUCTION_PROCESSING_MAX_RETRIES=3

# مدت زمان کش (دقیقه)
CACHE_TTL_MINUTES=5

# حداکثر حجم فایل آپلود (کیلوبایت)
MAX_UPLOAD_SIZE=10240

# فرمت‌های مجاز تصویر
ALLOWED_IMAGE_FORMATS=jpg,jpeg,png,webp

# ========================================
# تنظیمات HTTPS (برای محیط تولید)
# ========================================

# فعال‌سازی HTTPS اجباری در production
# FORCE_HTTPS=true
